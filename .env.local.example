# LLM Provider (admin switches by changing these values)
ACTIVE_PROVIDER=anthropic          # anthropic | openai | google
ACTIVE_MODEL=claude-opus-4         # model string for the active provider

# Provider API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Auth
NEXTAUTH_SECRET=                   # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (Vercel Postgres)
DATABASE_URL=

# Real-time (Vercel KV)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
MCP_ENCRYPTION_KEY=

# AI assistant name (used for @mentions in shared sessions, default: keeper)
NEXT_PUBLIC_AI_NAME=keeper
